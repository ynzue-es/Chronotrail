# Chronotrail production reverse proxy.
# Caddy terminates TLS (auto Let's Encrypt) and routes:
#   chronotrail.fr      -> Next.js web app  (web:3000)
#   api.chronotrail.fr  -> Supabase gateway (kong:8000)

# --- Web app (apex) ---
chronotrail.fr {
    encode zstd gzip
    reverse_proxy web:3000
    header -server
}

# --- Supabase API ---
api.chronotrail.fr {
    encode zstd gzip
    reverse_proxy kong:8000
    header -server
}
